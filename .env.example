# URL publique du projet Supabase (visible côté client)
NEXT_PUBLIC_SUPABASE_URL=https://votre-projet.supabase.co

# Clé anonyme Supabase (visible côté client — sécurisée par les RLS policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key

# Clé service role Supabase (SECRÈTE — ne jamais exposer côté client)
# Utilisée uniquement dans les API routes serveur
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# URL publique de l'application (utilisée pour les liens QR code)
NEXT_PUBLIC_APP_URL=https://votre-domaine.com
